# PaintLearn backend env vars 範本（複製為 .env 後填值；勿 commit .env）
#
# Railway 部署：
#   - DATABASE_URL / REDIS_URL：由 Railway Postgres / Redis plugin 自動注入
#   - 其他：在 Railway Variables 手動設定（建議走 Shared Variables 兩個 service 共用）

# ── DB ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/yiimui
TEST_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/yiimui_test

# ── Auth ───────────────────────────────────────────────────────────────────
# 生 256-bit random：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_random_256bit_hex
JWT_ALGORITHM=HS256

# ── Email（Resend）─────────────────────────────────────────────────────────
# domain 沒 verify 前用 onboarding@resend.dev（限制：只能寄到自己 email）
# domain 驗證後改：RESEND_FROM_EMAIL=noreply@yiimui.com（建議）或 hello@yiimui.com
# 顯示名稱版本：RESEND_FROM_EMAIL="易木 YIIMUI <noreply@yiimui.com>"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── 前後端 URL（CORS + Email 內連結）──────────────────────────────────────
# 本地開發
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
# Production（自有網域 yiimui.com 串接後）：
#   FRONTEND_URL=https://yiimui.com
#   ADMIN_URL=https://admin.yiimui.com
# 注意：FRONTEND_URL 也用於 email 內的連結（驗證信、重設密碼）—
# 必須是客戶能訪問到的網址（不能是 vercel.app 子網域，否則信件會像釣魚信）

# ── Firebase Storage ───────────────────────────────────────────────────────
# 本地：service account JSON 檔案路徑（推薦放 backend/service-account.json）
FIREBASE_CREDENTIALS=./service-account.json
# Railway：用 base64 編碼 JSON，runtime 自動偵測解碼
#   生指令：base64 -w0 service-account.json | clip   （Linux/WSL）
#   或：    [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))   (PowerShell)
# FIREBASE_CREDENTIALS_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
FIREBASE_STORAGE_BUCKET=paint-by-number-d9fa3.firebasestorage.app

# ── Celery / Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── SAM model（Phase B production sam_refine / sam_weighted）───────────────
# Linux 部署：Dockerfile 內 ENV 已預設 /app/models/sam_vit_b.pth，這裡可省略
# 本地 Windows 開發：指向 paint-by-number/models/sam_vit_b.pth
SAM_MODEL_PATH=../paint-by-number/models/sam_vit_b.pth

# ── Inkscape（PDF 匯出）────────────────────────────────────────────────────
# Linux 部署：Dockerfile 預設 /usr/bin/inkscape
# 本地 Windows：寫死於 export_pdf.py，可不設
# INKSCAPE_PATH=/usr/bin/inkscape
